{
  "name": "pr-glow",
  "displayName": "PR Glow",
  "description": "Purple gutter highlights for lines changed in your branch's open pull request. Supports GitHub and Bitbucket Cloud.",
  "version": "0.1.0",
  "publisher": "kwol",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kevzzsk/pr-glow.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "pull request",
    "gutter",
    "review",
    "github",
    "bitbucket",
    "diff"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "prGlow.refresh",
        "title": "PR Glow: Refresh"
      },
      {
        "command": "prGlow.setBitbucketCredentials",
        "title": "PR Glow: Set Bitbucket Credentials"
      },
      {
        "command": "prGlow.signInGitHub",
        "title": "PR Glow: Sign in to GitHub"
      },
      {
        "command": "prGlow.openPr",
        "title": "PR Glow: Open Pull Request in Browser"
      }
    ],
    "configuration": {
      "title": "PR Glow",
      "properties": {
        "prGlow.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable PR gutter highlighting."
        },
        "prGlow.gutterColor.dark": {
          "type": "string",
          "default": "#A371F7",
          "description": "Gutter marker color used with dark themes."
        },
        "prGlow.gutterColor.light": {
          "type": "string",
          "default": "#8250DF",
          "description": "Gutter marker color used with light themes."
        },
        "prGlow.githubEnterpriseUrl": {
          "type": "string",
          "default": "",
          "description": "Base URL of your GitHub Enterprise instance (e.g. https://github.mycompany.com). Leave empty for github.com."
        },
        "prGlow.remoteName": {
          "type": "string",
          "default": "origin",
          "description": "Git remote used to detect the hosting provider and pull requests."
        }
      }
    },
    "colors": [
      {
        "id": "prGlow.overviewRulerColor",
        "description": "Overview ruler color for lines changed in the active pull request.",
        "defaults": {
          "dark": "#A371F799",
          "light": "#8250DF99",
          "highContrast": "#A371F7"
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "npm run typecheck && node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:activation": "npm run compile && node test-integration/runTest.mjs",
    "smoke": "esbuild scripts/live-smoke.mts --bundle --platform=node --format=esm --outfile=dist/live-smoke.mjs --log-level=warning && node dist/live-smoke.mjs",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "1.85.0",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.3.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
